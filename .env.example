# =============================================================================
# VANGUARD-X — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git. The .gitignore protects you, but stay paranoid.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
VANGUARDX_ENVIRONMENT=development          # development | staging | production
VANGUARDX_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
VANGUARDX_DATA_DIR=./data                  # persistent volume (db, evidence, reports)

# --- Database --------------------------------------------------------------
# SQLite (dev default). For prod use postgresql+asyncpg://user:pass@host/db
VANGUARDX_DATABASE_URL=sqlite+aiosqlite:///./data/vanguard.db

# --- Scope enforcement (CRITICAL — safety boundary) ------------------------
# Comma-separated list of authorized targets. Subdomains of listed hosts
# are permitted automatically. Any scan against a target NOT in this list
# will raise ScopeViolation and halt immediately.
# Example: VANGUARDX_AUTHORIZED_TARGETS=example.com,10.0.0.0/24,dvwa.local
VANGUARDX_AUTHORIZED_TARGETS=

# --- Tool runner -----------------------------------------------------------
# How to invoke external tools:
#   local       -> subprocess on the host / inside the core container
#   docker_exec -> `docker exec` into named tool containers (production)
VANGUARDX_TOOL_RUNNER=local
VANGUARDX_NMAP_CONTAINER=vanguardx-nmap
VANGUARDX_HARVESTER_CONTAINER=vanguardx-harvester
VANGUARDX_SUBFINDER_CONTAINER=vanguardx-subfinder
VANGUARDX_WHATWEB_CONTAINER=vanguardx-whatweb
VANGUARDX_WAFW00F_CONTAINER=vanguardx-wafw00f
VANGUARDX_TOOL_TIMEOUT_SECONDS=600

# --- Notifications: Telegram ----------------------------------------------
# Create a bot via @BotFather, then start a chat with it and grab the chat_id.
# Leave both blank to silently disable notifications (useful in CI / tests).
VANGUARDX_TELEGRAM_BOT_TOKEN=
VANGUARDX_TELEGRAM_CHAT_ID=

# --- LLM (reserved for Phase 3 — Months 5-7) ------------------------------
# Not used in Phase 1. Documented here so the .env stays stable across phases.
ANTHROPIC_API_KEY=
VANGUARDX_LLM_MODEL=claude-opus-4-5
VANGUARDX_OLLAMA_BASE_URL=http://localhost:11434

# --- Continuous monitoring (Phase 1 Month 2) ------------------------------
VANGUARDX_RECON_INTERVAL_HOURS=24
